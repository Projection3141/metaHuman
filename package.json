{
  "name": "integrated-bot-management-system",
  "version": "1.0.1",
  "private": true,
  "description": "Multi platform automation bot for Reddit / Instagram / DCInside",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "reddit": "node platforms/reddit/runReddit.js",
    "instagram": "node platforms/instagram/runInstagram.js",
    "dc": "node platforms/dcinside/runDcinside.js"
  },
  "build": {
    "asar": true,
    "asarUnpack": [
      "bin/**/*"
    ],
    "appId": "xyz.tailorchain.IBMS",
    "productName": "integrated-bot-management-system",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "dotenv": "^17.2.4",
    "fs": "^0.0.1-security",
    "path": "^0.12.7",
    "puppeteer": "^24.15.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1"
  }
}